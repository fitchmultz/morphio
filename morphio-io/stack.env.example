# Common settings
APP_ENV=production
NODE_ENV=production
DEBUG=False
LOG_LEVEL=INFO
APP_PORT=8000
SECRET_KEY=secure_prod_key_here
RATE_LIMITING_ENABLED=True
UVICORN_WORKERS=2

# JWT settings
JWT_SECRET_KEY=secure_production_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS settings
CORS_ORIGINS="[\"https://morphio.io\", \"http://morphio.io\", \"https://www.morphio.io\", \"http://localhost:3000\"]"
NEXT_PUBLIC_API_BASE_URL=https://api.morphio.io
REACT_APP_MAX_UPLOAD_SIZE=3221225472

# Redis settings
REDIS_URL=redis://redis:6379
REDIS_CONF_PATH=./redis.conf

# AI/LLM settings
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AUDIO_TRANSCRIPTION_MODEL=local
WHISPER_MODEL=small
WHISPER_MLX_MODEL=small
TITLE_GENERATION_MODEL=gpt-4o
CONTENT_MODEL=gpt-4o
CONTENT_TEMPERATURE=1.0

# File upload settings
MAX_UPLOAD_SIZE=3221225472
FILE_CHUNK_SIZE=1048576
TEMPLATE_DIR=./templates/
UPLOAD_DIR=./uploads/
ALLOWED_MEDIA_EXTENSIONS="[\"mp4\",\"avi\",\"mov\",\"wmv\",\"flv\",\"mkv\",\"webm\",\"ogg\",\"3gp\",\"mpeg\",\"mpg\",\"m4v\",\"mp3\",\"wav\",\"ogg\",\"m4a\",\"aac\",\"flac\",\"wma\",\"m4p\"]"
