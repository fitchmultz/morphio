# Morphio Frontend - Environment Variables Example
# Copy this file to .env.local and update with your actual values

# Backend API Base URL
# Development: http://localhost:8000
# Production: https://api.morphio.io
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Allowed Audio Extensions (optional - JSON array format)
# NEXT_PUBLIC_ALLOWED_AUDIO_EXTENSIONS=["mp3","wav","m4a","aac","flac","wma","m4p"]
