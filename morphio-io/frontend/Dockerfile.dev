FROM node:24-alpine

WORKDIR /app

RUN corepack enable && corepack prepare "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa" --activate

# Copy dependency files
COPY frontend/package.json frontend/pnpm-lock.yaml ./

# Install with pnpm store cache
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Copy source
COPY frontend/ ./

EXPOSE 3005 9229

ENV WATCHPACK_POLLING=true \
    CHOKIDAR_USEPOLLING=true

CMD ["pnpm", "dev"]
