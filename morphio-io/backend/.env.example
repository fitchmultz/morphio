# Morphio Backend - Environment Variables Example
# Copy this file to .env and update with your actual values

# Application Environment
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
APP_PORT=8005  # Dev uses 8005, production uses 8000
UVICORN_WORKERS=2
REGISTRATION_ENABLED=True

# Security (REQUIRED in production - must be strong, non-default values)
# Generate strong secrets: openssl rand -base64 48
SECRET_KEY=dev_secret_key
JWT_SECRET_KEY=dev_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin User (optional - if ADMIN_PASSWORD is set, admin user will be auto-created)
ADMIN_EMAIL=admin@morphio.io
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3005","https://morphio.io"]

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0
JOB_CACHE_TTL=3600

# AI/LLM API Keys (required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGING_FACE_TOKEN=
GEMINI_API_KEY=

# Model Configuration
AUDIO_TRANSCRIPTION_MODEL=local
WHISPER_MODEL=small
WHISPER_MLX_MODEL=small
TITLE_GENERATION_MODEL=gemini-3-flash-preview-minimal
CONTENT_MODEL=gemini-3-flash-preview
CONTENT_TEMPERATURE=1.0
GEMINI_MEDIA_RESOLUTION=MEDIA_RESOLUTION_UNSPECIFIED

# Rate Limiting
RATE_LIMITING_ENABLED=True

# File Upload Settings
MAX_UPLOAD_SIZE=3221225472
FILE_CHUNK_SIZE=1048576
TEMPLATE_DIR=./templates/
UPLOAD_DIR=./uploads/

# Media Extensions (JSON arrays)
ALLOWED_VIDEO_EXTENSIONS=["mp4","avi","mov","wmv","flv","mkv","webm","ogg","3gp","mpeg","mpg","m4v"]
ALLOWED_AUDIO_EXTENSIONS=["mp3","wav","m4a","aac","flac","wma","m4p"]
ALLOWED_LOG_EXTENSIONS=["csv","json","log","md","txt"]

# Database Configuration
# Option 1: Use DATABASE_URL (recommended)
# DATABASE_URL=sqlite+aiosqlite:///./db/morphio_io.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/morphio

# Option 2: Use individual DB variables
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=morphio
DB_USER=morphio
DB_PASSWORD=

# External Service Endpoints (optional - for split services)
WORKER_ML_URL=
CRAWLER_URL=
SERVICE_TIMEOUT=60

# Stripe Configuration (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Usage and Subscription Configuration (JSON format)
USAGE_WEIGHTS_JSON={"VIDEO_PROCESSING":2,"AUDIO_PROCESSING":1,"WEB_SCRAPING":1,"CONTENT_GENERATION":2,"LOG_PROCESSING":1,"OTHER":1}
SUBSCRIPTION_PLAN_LIMITS_JSON={"free":50,"pro":1000,"enterprise":999999999}

# Docker Secrets Support (alternative to direct env vars)
# SECRET_KEY_FILE=/run/secrets/SECRET_KEY
# JWT_SECRET_KEY_FILE=/run/secrets/JWT_SECRET_KEY
# OPENAI_API_KEY_FILE=/run/secrets/OPENAI_API_KEY
# ANTHROPIC_API_KEY_FILE=/run/secrets/ANTHROPIC_API_KEY
# DATABASE_URL_FILE=/run/secrets/DATABASE_URL
# STRIPE_SECRET_KEY_FILE=/run/secrets/STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET_FILE=/run/secrets/STRIPE_WEBHOOK_SECRET
# REDIS_PASSWORD_FILE=/run/secrets/REDIS_PASSWORD
# DB_PASSWORD_FILE=/run/secrets/DB_PASSWORD
