# Docker specific (keep these first for better performance)
.docker/
docker-compose*.yml
docker-compose.override.yml
Dockerfile*
.dockerignore

# Version control
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml

# Dependencies
**/node_modules/
**/.npm/
**/.yarn/
**/.pnpm/
**/venv/
**/.venv/
pip-log.txt
pip-delete-this-directory.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
pnpm-debug.log*

