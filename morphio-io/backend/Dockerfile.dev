# syntax=docker/dockerfile:1.7
# Purpose: Build the Docker Compose development backend image used by local smoke validation.
# Responsibilities: Install backend dependencies, include ffmpeg, and run the development entrypoint with watch support.
# Scope: Local development/smoke backend image; production API, crawler, and worker-ml images have separate Dockerfiles.
# Usage: docker compose --env-file .env -f morphio-io/docker-compose.watch.yml up -d --build backend
# Invariants/Assumptions: uv.lock is the dependency source of truth; Docker/BuildKit caches may be reused because lockfiles and copied source layers invalidate stale inputs.
FROM python:3.14-slim AS builder

WORKDIR /app

# Install Rust for morphio-native and uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential \
 && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.93.1 \
 && pip install --no-cache-dir uv==0.10.8 \
 && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.cargo/bin:${PATH}" \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv

# Copy workspace configuration and members
COPY pyproject.toml uv.lock ./
COPY morphio-core/ morphio-core/
COPY morphio-native/ morphio-native/
COPY morphio-io/backend/ morphio-io/backend/

# Install dependencies (including building morphio-native)
# --no-editable ensures runtime doesn't need source paths
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --project morphio-io/backend --frozen --no-dev --no-editable

# Stage 2: Runtime
FROM python:3.14-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ffmpeg \
 && rm -rf /var/lib/apt/lists/*

# Copy venv and app from builder
COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/morphio-io/backend /app

ENV PATH="/app/.venv/bin:$PATH" \
    WATCHFILES_FORCE_POLLING=true

# Copy dev entrypoint
COPY morphio-io/backend/docker-entrypoint.dev.sh /docker-entrypoint.dev.sh
RUN chmod +x /docker-entrypoint.dev.sh

EXPOSE 8005 5678

CMD ["/docker-entrypoint.dev.sh"]
